# Copy to .env and adjust. All values are optional (sensible defaults shown).
PORT=3000
DATA_DIR=./data              # SQLite DB, uploaded scans, and the session secret
SEED=true                    # seed demo data when the database is empty

# --- Authentication ---------------------------------------------------------
# Public base URL, used to build OAuth callback URLs. Set this in production.
BASE_URL=http://localhost:3000
# Session cookie signing secret. If unset, a random one is generated and stored
# in DATA_DIR/.session_secret (persists across restarts). Set explicitly in prod.
# SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false          # set true when served over HTTPS (adds Secure flag)
# Comma-separated emails that should be admins on sign-up (first user is always admin)
ADMIN_EMAILS=

# OAuth providers — each is shown on the login page only when configured.
# Register the callback {BASE_URL}/api/auth/oauth/<provider>/callback with each provider.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# WECHAT_APPID=              # WeChat Open Platform "Website App"
# WECHAT_SECRET=

# --- AI assistant (OpenAI) --------------------------------------------------
# Server-side only; never exposed to the browser. Leave blank to disable the
# assistant (the panel then shows a "not configured" message).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5         # e.g. gpt-5.5, gpt-5.5-pro, gpt-5.4-mini

# --- Speech-to-text ---------------------------------------------------------
STT_PROVIDER=webspeech       # webspeech (browser) | whisper (self-hosted, on-prem)
STT_URL=http://whisper:9000  # base URL of the Whisper ASR webservice
ASR_MODEL=base               # tiny | base | small | medium | large-v3
ASR_ENGINE=faster_whisper    # faster_whisper (CPU-friendly) | openai_whisper
