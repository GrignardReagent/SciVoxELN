# Copy to .env and adjust. All values are optional (sensible defaults shown).
PORT=3000
DATA_DIR=./data          # where the SQLite DB and uploaded scans live
SEED=true                # seed demo data when the database is empty
STT_PROVIDER=webspeech   # webspeech | whisper
# STT_URL=http://localhost:9000   # external Whisper service when STT_PROVIDER=whisper
