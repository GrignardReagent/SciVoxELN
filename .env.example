# Copy to .env and adjust. All values are optional (sensible defaults shown).
PORT=3000
HOST=0.0.0.0                  # bind all interfaces; use 127.0.0.1 for local-only Node runs
DATA_DIR=./data              # SQLite DB, uploaded scans, and the session secret
SEED=true                    # seed demo data when the database is empty

# --- Public prototype / reverse proxy --------------------------------------
# No-domain prototype: run `docker compose --profile prototype up -d --build`,
# then copy the https://*.trycloudflare.com URL from `docker compose logs -f prototype-tunnel`.
# Leave BASE_URL blank so OAuth callback URLs are inferred from the tunnel host.
# Stable custom-domain tunnel: create a named Cloudflare Tunnel, publish your
# hostname to http://scivox:3000, paste the connector token below, then run
# `docker compose --profile tunnel up -d --build`.
DOMAIN=localhost              # only used by the permanent-domain Caddy profile
APP_BIND=127.0.0.1            # local host port bind; use 0.0.0.0 only for direct port exposure
APP_PORT=3000                 # host port for direct/local access without the Caddy profile
TRUST_PROXY=false             # set to 1 behind Caddy/Nginx/Cloudflare/tunnels
FORCE_HTTPS=false             # set true only for a stable HTTPS production proxy
CLOUDFLARED_TOKEN=            # named Cloudflare Tunnel token; keep secret

# --- Authentication ---------------------------------------------------------
# Public base URL for OAuth callbacks. Blank = infer current host/protocol.
# Set to https://your-domain only when you have a stable permanent domain.
BASE_URL=
# Session cookie signing secret. If unset, a random one is generated and stored
# in DATA_DIR/.session_secret (persists across restarts). Set explicitly in prod.
# SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false          # set true when using an HTTPS tunnel or production domain
# Comma-separated emails that should be admins on sign-up (first user is always admin)
ADMIN_EMAILS=
# For local/pilot setup without SMTP, set true only if you deliberately want
# reset/verification tokens returned in API responses. Keep false in production.
PASSWORD_RESET_EXPOSE_TOKEN=false
EMAIL_VERIFICATION_EXPOSE_TOKEN=false

# Optional backup location for `npm run backup`; defaults to DATA_DIR/backups.
BACKUP_DIR=

# OAuth providers — buttons are shown on the login page; each becomes enabled when configured.
# Register the callback {BASE_URL}/api/auth/oauth/<provider>/callback with each provider.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# WECHAT_APPID=              # WeChat Open Platform "Website App"
# WECHAT_SECRET=

# --- AI assistant (OpenAI) --------------------------------------------------
# Server-side only; never exposed to the browser. Leave blank to disable the
# assistant (the panel then shows a "not configured" message).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5         # e.g. gpt-5.5, gpt-5.5-pro, gpt-5.4-mini
OPENAI_VISION_MODEL=         # optional; defaults to OPENAI_MODEL for Observe run visual notes

# --- Speech-to-text ---------------------------------------------------------
STT_PROVIDER=auto            # auto | webspeech (browser) | openai | whisper (self-hosted)
STT_OPENAI_MODEL=gpt-4o-mini-transcribe
STT_URL=http://whisper:9000  # base URL of the Whisper ASR webservice
ASR_MODEL=base               # tiny | base | small | medium | large-v3
ASR_ENGINE=faster_whisper    # faster_whisper (CPU-friendly) | openai_whisper
