{
  "name": "scivox-eln",
  "version": "1.0.0",
  "description": "SciVox ELN — a voice- and vision-powered Electronic Lab Notebook with a compliant audit trail, experiment planner, inventory, and an AI assistant.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --watch --env-file-if-exists=.env src/index.js",
    "seed": "node --env-file-if-exists=.env src/seed.js",
    "backup": "node --env-file-if-exists=.env scripts/backup.js",
    "restore": "node --env-file-if-exists=.env scripts/restore.js",
    "workflow:install": "node scripts/tracking.js install",
    "workflow:check": "node scripts/tracking.js check",
    "workflow:append": "node scripts/tracking.js append-draft",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^2.0.0"
  },
  "author": "SciVox",
  "license": "UNLICENSED",
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
